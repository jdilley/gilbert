# Gilbert installation data (per-instance config, database, logs, plugin cache)
.gilbert/

# Plugin directories
#
# std-plugins/ — the first-party gilbert-plugins repository. Users
#   clone briandilley/gilbert-plugins into this directory; it has its
#   own git history and isn't tracked by the main gilbert repo.
# local-plugins/ — plugins the user writes locally. Never tracked.
# installed-plugins/ — plugins fetched at runtime from external sources
#   (GitHub URLs, etc.). Managed by the plugin loader.
#
# We keep the empty directory scaffolds around (via .gitkeep) so
# gilbert.yaml's ``plugins.directories`` works out of the box on a
# fresh clone without the user having to mkdir anything.
std-plugins/
local-plugins/*
!local-plugins/README.md
installed-plugins/*
!installed-plugins/README.md

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# Virtual environment
.venv/

# Testing
.pytest_cache/
.coverage
htmlcov/

# IDE
.idea/
.vscode/
*.swp
*.swo

# mypy
.mypy_cache/

# ruff
.ruff_cache/

# Frontend build
frontend/node_modules/
frontend/dist/
src/gilbert/web/spa/
